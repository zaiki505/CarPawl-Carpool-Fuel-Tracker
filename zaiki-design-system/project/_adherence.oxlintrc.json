{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "reference/site/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='BentoCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|main|href|linkText|chips|children|style|key|ref|className|style|children)$/]",
        "message": "<BentoCard> doesn't accept that prop. Declared props: title, main, href, linkText, chips, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Breadcrumb'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|current|key|ref|className|style|children)$/]",
        "message": "<Breadcrumb> doesn't accept that prop. Declared props: items, current."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|href|onClick|squishy|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, href, onClick, squishy, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|pill|action|theme)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'pill' | 'action' | 'theme'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CyberCat'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|hint|key|ref|className|style|children)$/]",
        "message": "<CyberCat> doesn't accept that prop. Declared props: size, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|textarea|rows|name|placeholder|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<FormField> doesn't accept that prop. Declared props: label, type, textarea, rows, name, placeholder, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|visible|children|key|ref|className|style|children)$/]",
        "message": "<FormStatus> doesn't accept that prop. Declared props: state, visible, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormStatus'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:success|error)$/]",
        "message": "<FormStatus> state must be one of 'success' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:links|active|logo|logoText|onNavigate|showTheme|onThemeToggle|style|key|ref|className|style|children)$/]",
        "message": "<NavPill> doesn't accept that prop. Declared props: links, active, logo, logoText, onNavigate, showTheme, onThemeToggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|tags|image|gradient|href|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: title, description, tags, image, gradient, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScrollTopButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:onClick|style|key|ref|className|style|children)$/]",
        "message": "<ScrollTopButton> doesn't accept that prop. Declared props: onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tier|children|key|ref|className|style|children)$/]",
        "message": "<SkillChip> doesn't accept that prop. Declared props: tier, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillChip'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:advanced|intermediate|beginner)$/]",
        "message": "<SkillChip> tier must be one of 'advanced' | 'intermediate' | 'beginner'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: category, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:web|system|creative|personal)$/]",
        "message": "<Tag> category must be one of 'web' | 'system' | 'creative' | 'personal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:year|title|kicker|logo|children|key|ref|className|style|children)$/]",
        "message": "<TimelineItem> doesn't accept that prop. Declared props: year, title, kicker, logo, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
